# ─────────────────────────────────────────────
#  ApexVision-Core — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
DEBUG=true
LOG_LEVEL=DEBUG
PORT=8000
API_WORKERS=2

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
MASTER_API_KEY=apexvision-master-key-change-in-prod

# CORS (restrict in production)
CORS_ORIGINS=["*"]

# Database
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apexvision

# Redis (winget install Redis.Redis in Windows dev)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_CONCURRENCY=4

# ML Models — cpu | cuda | mps
DEVICE=cpu
YOLO_MODEL=yolov11n.pt
CLIP_MODEL=openai/clip-vit-base-patch32

# Storage
LOCAL_STORAGE_PATH=./data
DELTA_LAKE_PATH=./data/delta
PARQUET_PATH=./data/parquet
MODELS_PATH=./models
MAX_UPLOAD_SIZE_MB=50

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Flower (Celery monitor)
FLOWER_USER=admin
FLOWER_PASSWORD=apexvision

# Docker ports (override if needed)
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
FLOWER_PORT=5555
